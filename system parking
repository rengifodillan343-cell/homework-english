parking_spaces = [None] * 10
import time

while True:
    print("="*40)
    print("\n    ---  PARKING LOT MENU   ---")
    print("_"*40)
    print("1. Show parking spaces status")
    print("")
    print("2. Park a car")
    print("")
    print("3. Remove a car")
    print("")
    print("4. Exit")
    print("_"*40)
    print("")

    option = input("Select an option: ")

    if option == "1":
            print("\nCURRENT STATUS: ")
            for i, plate in enumerate(parking_spaces):
                status = f"OCCUPIED [{plate}]" if plate else "AVAILABLE"
                print(f" Space {i + 1}: {status}")
                time.sleep(0.5)

    elif option == "2":
        if None not in parking_spaces:
            print("Error! The parking lot is full.")
        else:
            plate = input("Enter the car license plate: ").upper()
            index = parking_spaces.index(None)
            parking_spaces[index] = plate
            print(f"Car with plate {plate} parked in space {index + 1}.")
    
    elif option == "3":
         plate = input("Enter the license plate to remove: ").upper()
         if plate in parking_spaces:
              index = parking_spaces.index(plate)
              parking_spaces[index] = None
              print(f"Car with plate {plate} removed from space {index + 1} successfully.")
         else:
              print("This plate is not registered in the parking lot system. Please check and try again.")

    elif option == "4":
         print("Exiting the program...")
         break
    else:
         print("Invalid option. Please try again.")
